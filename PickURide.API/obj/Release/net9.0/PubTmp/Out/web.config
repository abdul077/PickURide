<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
    <system.webServer>
      <!-- Remove WebDAV module -->
      <modules runAllManagedModulesForAllRequests="false">
        <remove name="WebDAVModule" />
      </modules>
      <!-- Remove WebDAV handler -->
      <handlers>
        <remove name="WebDAV" />
        <add name="aspNetCore" path="*" verb="*" modules="AspNetCoreModuleV2" resourceType="Unspecified" />
      </handlers>
      <!-- IMPORTANT: SmarterASP.NET requires outofprocess hosting model -->
      <aspNetCore processPath="dotnet" arguments=".\PickURide.API.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="outofprocess" forwardWindowsAuthToken="false" startupTimeLimit="3600" requestTimeout="00:20:00">
        <environmentVariables>
          <!-- Use Production for live site, Development only for debugging -->
          <environmentVariable name="ASPNETCORE_ENVIRONMENT" value="Production" />
          <!-- Disable HTTPS redirection if you don't have SSL configured -->
          <environmentVariable name="ASPNETCORE_FORWARDEDHEADERS_ENABLED" value="true" />
        </environmentVariables>
      </aspNetCore>
      <!-- Show detailed errors temporarily (REMOVE after debugging) -->
      <httpErrors errorMode="Detailed" />
      <!-- Required for SmarterASP.NET -->
      <httpProtocol>
        <customHeaders>
          <remove name="X-Powered-By" />
          <add name="X-Content-Type-Options" value="nosniff" />
        </customHeaders>
      </httpProtocol>
      <!-- Security settings -->
      <security>
        <requestFiltering removeServerHeader="true">
          <requestLimits maxAllowedContentLength="52428800" />
        </requestFiltering>
      </security>
      <!-- Disable static file caching during debugging -->
      <staticContent>
        <clientCache cacheControlMode="DisableCache" />
      </staticContent>
    </system.webServer>
  </location>
</configuration>
